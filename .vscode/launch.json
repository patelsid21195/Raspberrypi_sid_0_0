{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run robot main",
      "type": "debugpy",
      "request": "launch",
      "module":"src.main",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run robot tests",
      "type": "debugpy",
      "request": "launch",
      "module":"pytest",
      "args": ["tests"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}